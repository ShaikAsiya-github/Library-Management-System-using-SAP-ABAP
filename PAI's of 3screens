  CASE sy-ucomm.

    WHEN 'BACK'.
      LEAVE TO SCREEN 0.                          "Navigates to previous screen

    WHEN 'ENTER'.                                 "When we give book id student id/teacher id should come
      IF ztabu_lib-book_id IS NOT INITIAL.
        SELECT SINGLE issued_to
          FROM ztabu_lib
          WHERE book_id = @ztabu_lib-book_id
          INTO @ztabu_lib-issued_to.

